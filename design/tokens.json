  "shadow": {
    "sm":     "0 1px 2px rgba(0, 0, 0, 0.2)",
    "md":     "0 4px 12px rgba(0, 0, 0, 0.35)",
    "lg":     "0 12px 40px rgba(0, 0, 0, 0.5)",
    "window": "0 28px 70px rgba(0, 0, 0, 0.55), 0 0 0 0.5px #313244"
