  "font": {
    "familyBase": "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', system-ui, sans-serif",
    "familyMono": "'JetBrains Mono', 'SF Mono', 'Cascadia Code', ui-monospace, monospace",

    "sizeXs":   "10px",
    "sizeSm":   "11px",
    "sizeBase": "12px",
    "sizeMd":   "13px",
    "sizeLg":   "14px",
    "sizeXl":   "17px",
    "size2xl":  "19px",

    "weightNormal":   400,
    "weightMedium":   500,
    "weightSemibold": 600,
    "weightBold":     700,

    "lineHeightTight":   1.3,
    "lineHeightBase":    1.5,
    "lineHeightRelaxed": 1.6
  },

  "space": {
    "1":  "4px",
    "2":  "8px",
    "3":  "12px",
    "4":  "16px",
    "5":  "20px",
    "6":  "24px",
    "8":  "32px",
    "10": "40px",
    "12": "48px"
